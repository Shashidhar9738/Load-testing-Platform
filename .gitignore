# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
venv/
.venv/
env/

# Database (auto-created on first run)
*.db
*.db-wal
*.db-shm

# App config (auto-created, contains local paths)
.ltconfig.json

# Secret key (auto-generated on first run — never commit)
.lt_secret

# Client data (contains client-sensitive JTL results and test data)
clients/*/reports/
clients/*/testdata/
clients/*/jmx/

# Logs
*.log
jmeter.log

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.suo
*.user

# Temp files
tmp/
temp/
*.tmp
