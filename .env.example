# Load Testing Platform — environment variable reference
# Copy this file to .env and adjust values. Never commit .env to source control.

# ── Secret key ────────────────────────────────────────────────────────────────
# If not set, a random key is auto-generated and saved to .lt_secret on first run.
# Set this explicitly in production so sessions survive restarts.
# LT_SECRET_KEY=replace-with-a-long-random-string

# ── TLS / Webhook ─────────────────────────────────────────────────────────────
# Set to 1 ONLY if your Teams/Slack webhook endpoint uses a self-signed certificate.
# Default: TLS verification is enabled (secure).
# LT_WEBHOOK_SKIP_TLS=0

# ── Flask ─────────────────────────────────────────────────────────────────────
# FLASK_ENV=production
# FLASK_DEBUG=0
