          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Generate SESSION_ID" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">  def chars = (&apos;0&apos;..&apos;9&apos;)
  def rnd = new Random()
  def timestamp = System.currentTimeMillis().toString()
  def remaining = 20 - timestamp.length()
  def randomPart = (1..remaining).collect { chars[rnd.nextInt(chars.size())] }.join()                 
  def sessionId = timestamp + randomPart
  vars.put(&apos;SESSION_ID&apos;, sessionId)</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert - Balance Enquiry 001" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">String displayExpected = &quot;Enter your 4 digit PIN&quot;
String actual = (prev.getResponseDataAsString() ?: &quot;&quot;).trim()
String actualShort = actual.length() &gt; 400 ? actual.substring(0,400) + &quot;...&quot; : actual
if (!actual.contains(&quot;Enter 4 digit pin Or call 1333 to reset pin&quot;)) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;Expected: ${displayExpected} | Actual: ${actualShort}&quot;)
}</stringProp>
            </JSR223Assertion>
            <hashTree/>
          </hashTree>
