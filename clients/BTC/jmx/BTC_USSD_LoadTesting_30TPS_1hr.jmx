            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Generate SESSION_ID" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">  def chars = (&apos;0&apos;..&apos;9&apos;)
  def rnd = new Random()
  def timestamp = System.currentTimeMillis().toString()
  def remaining = 20 - timestamp.length()
  def randomPart = (1..remaining).collect { chars[rnd.nextInt(chars.size())] }.join()                 
  def sessionId = timestamp + randomPart
  vars.put(&apos;SESSION_ID&apos;, sessionId)</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
