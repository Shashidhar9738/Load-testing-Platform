String actualShort = actual.length() &gt; 400 ? actual.substring(0,400) + &quot;...&quot; : actual
if (!(actual =~ /Enter 4 digit pin Or call 1333 to reset pin/)) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;Expected: ${displayExpected} | Actual: ${actualShort}&quot;)
}</stringProp>
            </JSR223Assertion>
