              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">String displayExpected = &quot;Enter your 4 digit PIN&quot;
String actual = (prev.getResponseDataAsString() ?: &quot;&quot;).trim()
String actualShort = actual.length() &gt; 400 ? actual.substring(0,400) + &quot;...&quot; : actual
if (!actual.contains(&quot;Enter 4 digit pin Or call 1333 to reset pin&quot;)) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;Expected: ${displayExpected} | Actual: ${actualShort}&quot;)
}</stringProp>
